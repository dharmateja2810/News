generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Existing Models ───────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String     @map("password_hash")
  name           String?
  theme          String     @default("light")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  emailVerified  Boolean?   @default(false) @map("email_verified")
  verifyToken    String?    @map("verify_token") @db.VarChar(255)
  verifyTokenExp DateTime?  @map("verify_token_exp") @db.Timestamp(6)
  googleId       String?    @unique @map("google_id") @db.VarChar(255)
  appleId        String?    @unique @map("apple_id") @db.VarChar(255)
  avatarUrl      String?    @map("avatar_url")
  bookmarks      Bookmark[]
  likes          Like[]

  @@map("users")
}

model Article {
  id              String           @id @default(uuid())
  title           String
  description     String?
  content         String?          @db.Text
  body            String?          @db.Text
  summary         String?          @db.Text
  imageUrl        String?          @map("image_url")
  source          String
  category        String
  author          String?
  publishedAt     DateTime?        @map("published_at")
  url             String           @unique
  scrapedAt       DateTime?        @default(now()) @map("scraped_at")
  isOpinion       Boolean          @default(false) @map("is_opinion")
  isPaywalled     Boolean          @default(false) @map("is_paywalled")
  sourceAuthority Float            @default(0.5) @map("source_authority")
  dedupHash       String?          @map("dedup_hash")
  processed       Boolean          @default(false)
  entities        Json?            @db.JsonB
  clusterId       String?          @map("cluster_id")
  cluster         StoryCluster?    @relation(fields: [clusterId], references: [id])
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  bookmarks       Bookmark[]
  likes           Like[]
  clusterLinks    ClusterArticle[]

  @@index([category])
  @@index([publishedAt])
  @@index([dedupHash])
  @@index([processed])
  @@index([clusterId])
  @@map("articles")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("bookmarks")
}

model Like {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("likes")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

// ─── Pipeline Models ───────────────────────────────────────────────────────────

model Source {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  rssUrl           String?  @map("rss_url")
  scrapeUrl        String?  @map("scrape_url")
  authorityScore   Float    @default(0.5) @map("authority_score")
  scrapeInterval   Int      @default(30) @map("scrape_interval") // minutes
  isActive         Boolean  @default(true) @map("is_active")
  requiresAuFilter Boolean  @default(false) @map("requires_au_filter")
  isPaywalled      Boolean  @default(false) @map("is_paywalled")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("sources")
}

model StoryCluster {
  id                 String           @id @default(uuid())
  topic              String?
  category           String?
  firstSeenAt        DateTime?        @map("first_seen_at")
  lastUpdatedAt      DateTime?        @map("last_updated_at")
  articleCount       Int              @default(0) @map("article_count")
  uniqueSourceCount  Int              @default(0) @map("unique_source_count")
  hasPaywalled       Boolean          @default(false) @map("has_paywalled")
  opinionRatio       Float            @default(0.0) @map("opinion_ratio")
  clusterQuality     Float            @default(0.0) @map("cluster_quality")
  ozScore            Float            @default(0.0) @map("oz_score")
  ozScoreMorning     Float            @default(0.0) @map("oz_score_morning")
  ozScoreEvening     Float            @default(0.0) @map("oz_score_evening")
  impactScore        Float?           @map("impact_score")
  auRelevanceScore   Float?           @map("au_relevance_score")
  engagementScore    Float?           @map("engagement_score")
  tier               Int?
  status             String           @default("active") // active | archived | suppressed
  articles           Article[]
  clusterArticles    ClusterArticle[]
  clusterContent     ClusterContent?

  @@index([ozScore])
  @@index([status])
  @@index([category])
  @@map("story_clusters")
}

model ClusterArticle {
  clusterId String       @map("cluster_id")
  articleId String       @map("article_id")
  isPrimary Boolean      @default(false) @map("is_primary")
  addedAt   DateTime     @default(now()) @map("added_at")
  cluster   StoryCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([clusterId, articleId])
  @@map("cluster_articles")
}

model ClusterContent {
  id           String       @id @default(uuid())
  clusterId    String       @unique @map("cluster_id")
  cluster      StoryCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  headline     String
  summary      String       @db.Text
  whyItMatters String?      @map("why_it_matters")
  doubleClick  String?      @map("double_click") @db.Text
  tier         Int
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("cluster_content")
}
